{
  "name": "cueflow",
  "version": "1.0.1",
  "description": "Automated meeting recorder triggered by email",
  "author": {
    "name": "Cueflow",
    "email": "dsbamarasinghe1234@gmail.com"
  },
  "homepage": "https://github.com/Dushmantha-Amarasinghe/cueflow",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "electron-vite build",
    "preview": "set ELECTRON_RUN_AS_NODE=0 && electron-vite preview",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "imapflow": "^1.3.5",
    "luxon": "^3.7.2",
    "mailparser": "^3.9.9",
    "node-ical": "^0.26.1",
    "node-schedule": "^2.1.1",
    "obs-websocket-js": "^5.0.8",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^29.4.6",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "lucide-react": "^0.344.0",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4"
  },
  "build": {
    "appId": "com.cueflow.app",
    "productName": "Cueflow",
    "publish": {
      "provider": "github",
      "owner": "Dushmantha-Amarasinghe",
      "repo": "cueflow",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico",
      "publisherName": "Cueflow",
      "artifactName": "Cueflow-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cueflow",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "uninstallDisplayName": "Cueflow ${version}"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "."
      }
    ]
  }
}
